@page "/architecturecouncil"
@rendermode InteractiveServer
@using ArchitectureCouncil.Web.ApiClients
@inject ArchitectureCouncilApiClient ApiClient
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Architecture Council</PageTitle>

<div class="council-container">
    <!-- Header -->
    <div class="council-header">
        <h1>🏛️ Architecture Council</h1>
        <p class="lead">Orchestrating Multi-Agent Workflows in .NET</p>
        <p class="text-muted">
            Three AI architects debate your technical decisions in real time.
            Get a balanced perspective and a final Architecture Decision Record (ADR).
        </p>
    </div>

    <!-- Agent Participants -->
    <div class="agents-panel">
        <div class="agent-card cloud-agent">
            <div class="agent-avatar">☁️</div>
            <div class="agent-info">
                <h6>Cloud-Native Advocate</h6>
                <small>Alex Chen · Senior Cloud Architect</small>
            </div>
        </div>

        <div class="vs-badge">VS</div>

        <div class="agent-card oss-agent">
            <div class="agent-avatar">🐧</div>
            <div class="agent-info">
                <h6>Open-Source Purist</h6>
                <small>Jordan Lee · Senior Software Architect</small>
            </div>
        </div>

        <div class="judge-separator">
            <span class="judge-label">Judged by</span>
        </div>

        <div class="agent-card lead-agent">
            <div class="agent-avatar">⚖️</div>
            <div class="agent-info">
                <h6>Lead Architect</h6>
                <small>Sam Rivera · Principal Architect</small>
            </div>
        </div>
    </div>

    <!-- Topic Input -->
    <div class="input-section">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-1">Debate Topic</h5>
                <p class="card-text text-muted small mb-3">
                    Describe the architectural decision your team is facing.
                </p>
                <div class="mb-3">
                    <textarea class="form-control"
                              rows="4"
                              @bind="debateContext"
                              placeholder="e.g., Should we use RabbitMQ or Azure Service Bus for our microservices event-driven architecture?"
                              disabled="@isDebating"></textarea>
                </div>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <button class="btn btn-outline-secondary btn-sm" @onclick='() => SetExample(1)' disabled="@isDebating">
                        💡 Message Broker
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick='() => SetExample(2)' disabled="@isDebating">
                        💡 Database
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick='() => SetExample(3)' disabled="@isDebating">
                        💡 Caching
                    </button>
                </div>
                <button class="btn btn-primary btn-lg w-100"
                        @onclick="StartDebateAsync"
                        disabled="@(isDebating || string.IsNullOrWhiteSpace(debateContext))">
                    @if (isDebating)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Debate in Progress…</span>
                    }
                    else
                    {
                        <span>🏛️ Start Debate</span>
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Debate Output -->
    @if (debateState != DebateState.Idle)
    {
        <div class="output-section">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 d-flex align-items-center">
                        @switch (debateState)
                        {
                            case DebateState.Debating:
                                <span class="status-dot debating"></span>
                                <span>Debate in Progress</span>
                                break;
                            case DebateState.Completed:
                                <span class="status-dot completed"></span>
                                <span>Debate Concluded</span>
                                break;
                            case DebateState.Error:
                                <span class="status-dot error"></span>
                                <span>Error</span>
                                break;
                        }
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="debate-transcript" @ref="transcriptElement">
                        <pre class="transcript-text">@debateOutput</pre>
                        @if (isDebating)
                        {
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }
</div>

@code {
    private string debateContext = string.Empty;
    private string debateOutput = string.Empty;
    private string? errorMessage;
    private bool isDebating;
    private DebateState debateState = DebateState.Idle;
    private ElementReference transcriptElement;
    private CancellationTokenSource? cts;

    private enum DebateState { Idle, Debating, Completed, Error }

    private void SetExample(int example)
    {
        debateContext = example switch
        {
            1 => "Should we use RabbitMQ or Azure Service Bus for our new microservices event-driven architecture? We are building an e-commerce platform with order processing, inventory updates, and notification services. We expect around 5,000 messages per minute at peak and the team is split between Azure-native and cloud-agnostic preferences.",
            2 => "Should we use PostgreSQL or Azure SQL Database for our new SaaS multi-tenant application? We need strong consistency, support for complex queries, row-level security for tenant isolation, and the ability to scale to 500+ tenants.",
            3 => "Should we use Redis OSS (self-hosted) or Azure Cache for Redis for our distributed caching layer? We have a high-traffic web API serving 10,000 requests per second and need sub-millisecond latency for session and catalog data.",
            _ => debateContext
        };
    }

    private async Task StartDebateAsync()
    {
        if (string.IsNullOrWhiteSpace(debateContext))
            return;

        debateOutput = string.Empty;
        errorMessage = null;
        isDebating = true;
        debateState = DebateState.Debating;
        cts?.Cancel();
        cts = new CancellationTokenSource();

        try
        {
            await foreach (var chunk in ApiClient.DebateArchitectureStreamingAsync(debateContext, cts.Token))
            {
                debateOutput += chunk;
                StateHasChanged();
                await ScrollToBottomAsync();
            }

            debateState = DebateState.Completed;
        }
        catch (OperationCanceledException)
        {
            debateState = DebateState.Completed;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            debateState = DebateState.Error;
        }
        finally
        {
            isDebating = false;
        }
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", transcriptElement);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected — safe to ignore.
        }
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
    }
}
